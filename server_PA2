#include <iostream>
#include <string>
#include <cstring>
#include <sys/socket.h>
#include <netinet/in.h>
#include <unistd.h>
#include <pthread.h>
#include <map>
#include <arpa/inet.h> // for inet_ntoa
extern "C" {
    #include "sqlite3.h"
}

using namespace std;

#define SERVER_PORT 4552

struct ClientData {
    int socket;
    string ip;
};

sqlite3* db;
pthread_mutex_t db_mutex = PTHREAD_MUTEX_INITIALIZER;
std::map<string, string> activeUsers;
pthread_mutex_t active_users_mutex = PTHREAD_MUTEX_INITIALIZER;

void* handle_client(void* arg) {
    ClientData* data = (ClientData*)arg;
    int client_socket = data->socket;
    string client_ip = data->ip; // Capture the IP address passed from main
    delete data; // Clean up the memory allocated in main

    int authID = -1; 
    string currentUser = "";
    char buffer[1024];

    while (true) {
        memset(buffer, 0, 1024);
        int valread = read(client_socket, buffer, 1024);
        if (valread <= 0) break;

        string message(buffer);
        //cout << "DEBUG: Server received: " << message << endl;
        string response = "404 Command Not Found\n";

        if (message.find("LOGIN") == 0) {
            char cmd[10], user[50], pass[50];
            if (sscanf(message.c_str(), "%s %s %s", cmd, user, pass) == 3) {
                sqlite3_stmt* stmt;
                const char* sql = "SELECT ID FROM Users WHERE user_name = ? AND password = ?;";
                
                pthread_mutex_lock(&db_mutex);
                if (sqlite3_prepare_v2(db, sql, -1, &stmt, NULL) == SQLITE_OK) {
                    sqlite3_bind_text(stmt, 1, user, -1, SQLITE_STATIC);
                    sqlite3_bind_text(stmt, 2, pass, -1, SQLITE_STATIC);
                    
                    if (sqlite3_step(stmt) == SQLITE_ROW) {
                        authID = sqlite3_column_int(stmt, 0);
                        currentUser = user;
                        response = "200 OK\n";

                        // Register user in the active list for WHO command
                        pthread_mutex_lock(&active_users_mutex);
                        activeUsers[currentUser] = client_ip; // client_ip comes from the struct
                        pthread_mutex_unlock(&active_users_mutex);
                        
                    } else {
                        response = "403 Wrong UserID or Password\n";
                    }
                }
                sqlite3_finalize(stmt);
                pthread_mutex_unlock(&db_mutex);
            }
        }
        else if (message.find("QUIT") == 0) {
            send(client_socket, "200 OK\n", 7, 0);
            break;
        }
        else if (authID == -1) {
            response = "403 Please Login First\n";
        }
        // --- BALANCE ---
        else if (message.find("BALANCE") == 0) {
            sqlite3_stmt* stmt;
            const char* sql = "SELECT usd_balance FROM Users WHERE ID = ?;";
            pthread_mutex_lock(&db_mutex);
            if (sqlite3_prepare_v2(db, sql, -1, &stmt, NULL) == SQLITE_OK) {
                sqlite3_bind_int(stmt, 1, authID);
                if (sqlite3_step(stmt) == SQLITE_ROW) {
                    double bal = sqlite3_column_double(stmt, 0);
                    response = "200 OK\nBalance: $" + to_string(bal) + "\n";
                }
            }
            sqlite3_finalize(stmt);
            pthread_mutex_unlock(&db_mutex);
        }
        // --- BUY <symbol> <qty> ---
        else if (message.find("BUY") == 0) {
            char cmd[10], sym[10];
            int qty;
            if (sscanf(message.c_str(), "%s %s %d", cmd, sym, &qty) == 3) {
                double price = 10.0; // Fixed price for assignment
                double total = qty * price;
                pthread_mutex_lock(&db_mutex);
                // Check balance, update user, and update stocks
                string updateBal = "UPDATE Users SET usd_balance = usd_balance - " + to_string(total) + " WHERE ID = " + to_string(authID) + " AND usd_balance >= " + to_string(total) + ";";
                if (sqlite3_exec(db, updateBal.c_str(), 0, 0, 0) == SQLITE_OK && sqlite3_changes(db) > 0) {
                    string updateStock = "INSERT INTO Stocks (stock_symbol, stock_balance, user_id) VALUES ('" + string(sym) + "', " + to_string(qty) + ", " + to_string(authID) + ") ON CONFLICT(stock_symbol, user_id) DO UPDATE SET stock_balance = stock_balance + " + to_string(qty) + ";";
                    sqlite3_exec(db, updateStock.c_str(), 0, 0, 0);
                    response = "200 OK\nBought " + to_string(qty) + " of " + sym + "\n";
                } else {
                    response = "403 Insufficient Funds\n";
                }
                pthread_mutex_unlock(&db_mutex);
            }
        }
        // --- SELL <symbol> <qty> ---
        else if (message.find("SELL") == 0) {
            char cmd[10], sym[10];
            int qty;
            if (sscanf(message.c_str(), "%s %s %d", cmd, sym, &qty) == 3) {
                pthread_mutex_lock(&db_mutex);
                string updateStock = "UPDATE Stocks SET stock_balance = stock_balance - " + to_string(qty) + " WHERE stock_symbol = '" + string(sym) + "' AND user_id = " + to_string(authID) + " AND stock_balance >= " + to_string(qty) + ";";
                if (sqlite3_exec(db, updateStock.c_str(), 0, 0, 0) == SQLITE_OK && sqlite3_changes(db) > 0) {
                    string updateBal = "UPDATE Users SET usd_balance = usd_balance + " + to_string(qty * 10.0) + " WHERE ID = " + to_string(authID) + ";";
                    sqlite3_exec(db, updateBal.c_str(), 0, 0, 0);
                    response = "200 OK\nSold " + to_string(qty) + " of " + sym + "\n";
                } else {
                    response = "403 Insufficient Stock\n";
                }
                pthread_mutex_unlock(&db_mutex);
            }
        }
        // --- DEPOSIT <amount> ---
        else if (message.find("DEPOSIT") == 0) {
            double amount;
            if (sscanf(message.c_str(), "DEPOSIT %lf", &amount) == 1) {
                string sql = "UPDATE Users SET usd_balance = usd_balance + " + to_string(amount) + " WHERE ID = " + to_string(authID) + ";";
                pthread_mutex_lock(&db_mutex);
                sqlite3_exec(db, sql.c_str(), 0, 0, 0);
                pthread_mutex_unlock(&db_mutex);
                response = "200 OK\n";
            }
        }
        // --- LIST ---
        else if (message.find("LIST") == 0) {
            sqlite3_stmt* stmt;
            string sql;
            
            pthread_mutex_lock(&db_mutex);
            
            if (currentUser == "Root") {
                // Root sees everything: Symbol, Amount, and which User ID owns it
                sql = "SELECT stock_symbol, stock_balance, user_id FROM Stocks;";
                response = "200 OK\nFull System Records:\n";
                if (sqlite3_prepare_v2(db, sql.c_str(), -1, &stmt, NULL) == SQLITE_OK) {
                    while (sqlite3_step(stmt) == SQLITE_ROW) {
                        response += "User[" + to_string(sqlite3_column_int(stmt, 2)) + "] ";
                        response += (char*)sqlite3_column_text(stmt, 0);
                        response += ": " + to_string(sqlite3_column_int(stmt, 1)) + "\n";
                    }
                }
            } else {
                // Regular users only see their own stocks
                sql = "SELECT stock_symbol, stock_balance FROM Stocks WHERE user_id = ?;";
                response = "200 OK\nYour Stocks:\n";
                if (sqlite3_prepare_v2(db, sql.c_str(), -1, &stmt, NULL) == SQLITE_OK) {
                    sqlite3_bind_int(stmt, 1, authID);
                    while (sqlite3_step(stmt) == SQLITE_ROW) {
                        response += (char*)sqlite3_column_text(stmt, 0);
                        response += ": " + to_string(sqlite3_column_int(stmt, 1)) + "\n";
                    }
                }
            }
            
            sqlite3_finalize(stmt);
            pthread_mutex_unlock(&db_mutex);
        }
        else if (message.find("WHO") == 0) {
            if (currentUser != "Root") {
                response = "403 Forbidden\n";
            } else {
                response = "200 OK\nThe list of the active users:\n";
                pthread_mutex_lock(&active_users_mutex);
                for (auto const& [name, ip] : activeUsers) {
                    response += name + " " + ip + "\n";
                }
                pthread_mutex_unlock(&active_users_mutex);
            }
        }
        else if (message.find("LOOKUP") == 0) {
            if (currentUser == "") {
                response = "401 Unauthorized\n";
            } else {
                string ticker = message.substr(7); // Extract ticker after "LOOKUP "
                ticker.erase(ticker.find_last_not_of(" \n\r\t") + 1); // trim whitespace

                sqlite3_stmt* stmt;
                // Use LIKE with % for partial matching
                string sql = "SELECT stock_symbol, stock_balance FROM Stocks WHERE user_id = ? AND stock_symbol LIKE ?;";
                
                pthread_mutex_lock(&db_mutex);
                if (sqlite3_prepare_v2(db, sql.c_str(), -1, &stmt, NULL) == SQLITE_OK) {
                    sqlite3_bind_int(stmt, 1, authID);
                    string searchPattern = "%" + ticker + "%";
                    sqlite3_bind_text(stmt, 2, searchPattern.c_str(), -1, SQLITE_STATIC);

                    string results = "";
                    int count = 0;
                    while (sqlite3_step(stmt) == SQLITE_ROW) {
                        results += string((char*)sqlite3_column_text(stmt, 0)) + " " + to_string(sqlite3_column_int(stmt, 1)) + "\n";
                        count++;
                    }

                    if (count > 0) {
                        response = "200 OK\nFound " + to_string(count) + " match\n" + results;
                    } else {
                        response = "404 Your search did not match any records.\n";
                    }
                }
                sqlite3_finalize(stmt);
                pthread_mutex_unlock(&db_mutex);
            }
        }
        else if (message.find("LOGOUT") == 0) {
            // 1. Check if anyone is actually logged in
            if (currentUser == "") {
                response = "401 Unauthorized\n";
            } else {
                cout << "User " << currentUser << " is logging out." << endl;
                
                // 2. Remove from active users map (Cleanup)
                pthread_mutex_lock(&active_users_mutex);
                activeUsers.erase(currentUser);
                pthread_mutex_unlock(&active_users_mutex);

                // 3. Reset session variables (The "Logout" part)
                authID = -1;
                currentUser = "";
                
                response = "200 OK\n";
                // Note: We do NOT break or close the socket here.
            }
        }
        else if (message.find("SHUTDOWN") == 0) {
            if (currentUser == "Root") {
                send(client_socket, "200 OK\n", 7, 0);
                exit(0);
            } else {
                response = "403 Admin Only\n";
            }
        }

        send(client_socket, response.c_str(), response.length(), 0);
    }
    pthread_mutex_lock(&active_users_mutex);
    if (currentUser != "") {
        activeUsers.erase(currentUser);
    }
    pthread_mutex_unlock(&active_users_mutex);

    close(client_socket);
    return NULL;
}

int main() {
    sqlite3_open("stocks.db", &db);
    sqlite3_exec(db, "CREATE TABLE IF NOT EXISTS Users (ID INTEGER PRIMARY KEY, user_name TEXT UNIQUE, password TEXT, usd_balance DOUBLE);", 0, 0, 0);
    sqlite3_exec(db, "CREATE TABLE IF NOT EXISTS Stocks (ID INTEGER PRIMARY KEY, stock_symbol TEXT, stock_balance INT, user_id INT, UNIQUE(stock_symbol, user_id));", 0, 0, 0);
    sqlite3_exec(db, "INSERT OR IGNORE INTO Users (user_name, password, usd_balance) VALUES ('Root','Root01',1000),('Mary','mary01',100),('John','john01',100),('Moe','moe01',100);", 0, 0, 0);

    int server_fd = socket(AF_INET, SOCK_STREAM, 0);
    int opt = 1;
    setsockopt(server_fd, SOL_SOCKET, SO_REUSEADDR, &opt, sizeof(opt));

    struct sockaddr_in addr;
    addr.sin_family = AF_INET;
    addr.sin_addr.s_addr = INADDR_ANY;
    addr.sin_port = htons(SERVER_PORT);

    bind(server_fd, (struct sockaddr *)&addr, sizeof(addr));
    listen(server_fd, 10);
    cout << "Server active on port " << SERVER_PORT << endl;

    while (true) {
        struct sockaddr_in client_addr;
        socklen_t addrlen = sizeof(client_addr);
        int conn_sock = accept(server_fd, (struct sockaddr *)&client_addr, &addrlen);

        if (conn_sock >= 0) {
            // Create the struct properly
            ClientData* data = new ClientData;
            data->socket = conn_sock;
            data->ip = inet_ntoa(client_addr.sin_addr); 

            pthread_t t;
            // Pass the STRUCT pointer, not an int pointer
            pthread_create(&t, NULL, handle_client, (void*)data); 
            pthread_detach(t);
    }
}
    return 0;
}